{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar ThreadPrivate",
            "type": "shell",
            "command": "make run-thread",
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Compilar FirstPrivate",
            "type": "shell",
            "command": "make run-first",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Compilar LastPrivate",
            "type": "shell",
            "command": "make run-last",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Correr Tests",
            "type": "shell",
            "command": "make run-tests",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": ["$gcc"]
        }
    ]
}
